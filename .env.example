# ═══════════════════════════════════════════════════════════════════
# OpenCode + Agent Vault — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:  cp .env.example .env
#
# Runtime: Apple Container (apple/container)
# Orchestration: container-compose (mcrich23/container-compose)
#
# NOTE: container-compose does NOT support ${VAR:-default} expansion.
# Variables are loaded from this .env file via the `env_file:` directive
# in compose.yml. Do NOT use ${VAR:-} syntax — use plain values.
#
# Quick start:
#   container system start
#   container-compose up -d agent-vault              # start credential proxy
#   container-compose build                          # build opencode image
#   <run bootstrap to push credentials — see below>  # one-shot credential sync
#   container-compose up -d                          # start all services
#   opencode attach http://localhost:4096 --password <OPENCODE_SERVER_PASSWORD>
#
# ═══════════════════════════════════════════════════════════════════

# -- Agent Vault Server --
# Master password for encrypting the agent-vault database.
# Generate: openssl rand -base64 32
AGENT_VAULT_MASTER_PASSWORD=

# -- Admin account (used by bootstrap + token-refresher) --
# Email + password for the agent-vault admin account. The bootstrap
# script registers the first user (becomes instance owner).
# The token-refresher uses these to read/write credentials.
AGENT_VAULT_EMAIL=
AGENT_VAULT_PASSWORD=

# The vault within agent-vault to use (created automatically by bootstrap).
AGENT_VAULT_VAULT=default

# -- OpenCode Server --
# Agent token — automatically generated by the bootstrap container and
# written to ~/.config/opencode/agent-token/agent-token on the host.
# You only need to set this manually if you're NOT using the bootstrap.
# AGENT_VAULT_TOKEN=

# Password for the opencode HTTP API (basic auth).
# Set this, then pass it when attaching from your host:
#   opencode attach http://localhost:4096 --password <this-value>
OPENCODE_SERVER_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# Bootstrap: one-shot credential push (manual)
# ═══════════════════════════════════════════════════════════════════
#
# After starting agent-vault, run the bootstrap container to push
# your opencode credentials from auth.json into agent-vault:
#
#   mkdir -p ~/.config/opencode/agent-token
#
#   container run --rm \
#     --volume ~/.local/share/opencode/auth.json:/tmp/auth.json:ro \
#     --volume ~/.config/opencode/agent-token:/token \
#     --network opencode-sandbox_internal \
#     -e AGENT_VAULT_ADDR=http://agent-vault:14321 \
#     -e AGENT_VAULT_EMAIL=$AGENT_VAULT_EMAIL \
#     -e AGENT_VAULT_PASSWORD=$AGENT_VAULT_PASSWORD \
#     agent-vault-bootstrap:latest
#
# The bootstrap container:
#   1. Registers the admin account in agent-vault
#   2. Reads your opencode auth.json (~/.local/share/opencode/auth.json)
#   3. Pushes API keys and OAuth tokens into the vault
#   4. Creates service rules (which host uses which credential)
#   5. Mints an agent token and writes it to ~/.config/opencode/agent-token/
#
# After bootstrap, start the opencode server:
#   container-compose up -d opencode
