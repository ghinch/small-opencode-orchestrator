{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
      "cc-safety-net",
      "envsitter-guard@latest",
      "@mohak34/opencode-notifier@latest"
  ],

  // ── Top tier (DeepSeek V4 Pro) ────────────────────────────────────
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "orchestrator": {
      "plan_post_approval_handoff_agent": "orchestrator",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium",
      "textVerbosity": "low",
      "temperature": 0.2
    },

    // ── Warden (strategic decision maker) ─────────────────────────
    "warden": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "textVerbosity": "medium",
      "temperature": 0.2
    },
    "security-reviewer": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "debugger": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "textVerbosity": "medium",
      "temperature": 0.2
    },

    // ── Flash tier (DeepSeek V4 Flash — all other agents) ─────────
    "code-executor": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "refactorer": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium",
      "temperature": 0.1
    },
    "code-reviewer": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "spec-critic": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "plan-runner": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium"
    },
    "api-docs-researcher": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "code-explorer": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium",
      "temperature": 0.2
    },
    "test-verifier": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "docs-reviewer": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "task-output-summarizer": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "permission": {
    "bash": {
      "*": "deny",

      // ── Force use of built-in tools over bash equivalents ────────
      // Prefer: Read over cat/head/tail, Glob over find/ls, Edit over sed/awk
      "grep *": "deny",
      "cat *": "deny",
      "head *": "deny",
      "tail *": "deny",
      "find *": "deny",
      "ls *": "deny",
      "echo *": "deny",

      // ── Safe read-only git (never mutates) ──────────────────────
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git stash list": "allow",
      "git branch": "allow",
      "git remote": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git blame *": "allow",
      "git merge-base *": "allow",

      // ── Same read-only commands via git -C (used by tooling) ────
      "git -C * status *": "allow",
      "git -C * diff *": "allow",
      "git -C * log *": "allow",
      "git -C * show *": "allow",
      "git -C * stash list": "allow",
      "git -C * branch": "allow",
      "git -C * remote": "allow",
      "git -C * ls-files *": "allow",
      "git -C * rev-parse *": "allow",
      "git -C * blame *": "allow",
      "git -C * merge-base *": "allow",

      // ── Safe local write git (mutates local only, recoverable) ──
      "git add *": "allow",
      "git commit *": "allow",
      "git stash *": "allow",

      // ── Same write commands via git -C ──────────────────────────
      "git -C * add *": "allow",
      "git -C * commit *": "allow",
      "git -C * stash *": "allow",

      // ── Potentially destructive — always ask ────────────────────
      "git checkout *": "ask",
      "git branch *": "ask",
      "git reset *": "ask",
      "git clean *": "ask",
      "git rebase *": "ask",
      "git push *": "ask",
      "git -C * checkout *": "ask",
      "git -C * branch *": "ask",
      "git -C * reset *": "ask",
      "git -C * clean *": "ask",
      "git -C * rebase *": "ask",
      "git -C * push *": "ask",

      // ── Catch-all for any other git command ─────────────────────
      "git *": "ask"
    }
  }
}

