{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
      "cc-safety-net@v0.9.0",
      "envsitter-guard@17e37f2f76ea2c3fcc793a9082e06ab01f6f2e82",
      "@mohak34/opencode-notifier@v0.2.5",
      "opencode-history-search@v1.4.1"
  ],

  // ── Top tier (DeepSeek V4 Pro) ────────────────────────────────────
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "medium",
      "textVerbosity": "medium"
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "medium",
      "textVerbosity": "medium"
    },
    "orchestrator": {
      "plan_post_approval_handoff_agent": "orchestrator",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium",
      "textVerbosity": "low",
      "temperature": 0.2
    },

    // ── Warden (strategic decision maker) ─────────────────────────
    "warden": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high",
      "textVerbosity": "medium",
      "temperature": 0.2
    },
    "security-reviewer": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high",
      "textVerbosity": "medium"
    },
    "debugger": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high",
      "textVerbosity": "medium",
      "temperature": 0.2
    },

    // ── Flash tier (DeepSeek V4 Flash — all other agents) ─────────
    "code-executor": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "textVerbosity": "medium"
    },
    "refactorer": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "textVerbosity": "medium",
      "temperature": 0.1
    },
    "code-reviewer": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "textVerbosity": "medium"
    },
    "spec-critic": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high",
      "textVerbosity": "medium"
    },
    "plan-runner": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "medium",
      "textVerbosity": "medium"
    },
    "api-docs-researcher": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "code-explorer": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium",
      "temperature": 0.2
    },
    "test-verifier": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "docs-reviewer": {
      "model": "opencode-go/deepseek-v4-flash",
      "textVerbosity": "medium"
    },
    "task-output-summarizer": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  },
  "autoupdate": true,
  "mcp": {
    "engram": {
      "command": [
        "/opt/homebrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "gh api -X GET *": "allow",
      "gh api --method GET *": "allow",
      "gh api *": "ask",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr status": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status": "allow",
      "gh issue status *": "allow",
      "gh repo view *": "allow",
      "gh repo list *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh workflow list *": "allow",
      "gh workflow view *": "allow",
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh search *": "allow",
      "gh label list *": "allow",
      "gh milestone list *": "allow",
      "gh project list *": "allow",
      "gh project view *": "allow",
      "gh gist list *": "allow",
      "gh gist view *": "allow",
      "gh auth status": "allow",
      "gh auth status *": "allow",
      "gh status": "allow",
      "gh *": "ask",
      "sonar *": "allow"
    }
  }
}
